# Copy this file to .env and fill values.
# Required for baseline inference:
LLM_PROVIDER=gemini
LLM_API_KEY=your_gemini_api_key
LLM_MODEL=gemini-2.5-flash-lite

# Optional for Gemini: if omitted and LLM_PROVIDER=gemini, inference.py defaults to
# https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_BASE_URL=

# Backward compatibility vars (optional)
OPENAI_API_KEY=
MODEL_NAME=
API_BASE_URL=

# Optional: fallback token for compatible routers
HF_TOKEN=

# Optional: environment server URL for inference.py
ENV_BASE_URL=http://localhost:8000

# Optional inference runtime tuning
MAX_STEPS=70
TEMPERATURE=0.0
SEED=42

# LLM call controls for free-tier quotas
MAX_LLM_CALLS_PER_TASK=8
LLM_RETRY_MAX=2
LLM_RETRY_SECONDS=35

# Ollama local alternative
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
# LLM_API_BASE_URL=http://localhost:11434/v1

# Optional server log level (structured JSON logging)
LOG_LEVEL=INFO
LOG_TO_FILE=0
LOG_FILE_PATH=logs/server.jsonl

# Inference logging mode
# 0 = normal mode (errors + final scores only)
# 1 = verbose mode (logs all request/step details)
INFERENCE_VERBOSE=0
INFERENCE_LOG_TO_FILE=0
INFERENCE_LOG_FILE_PATH=logs/inference.log
