# Copy this file to .env and fill values.
# Required for submission inference:
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=your_model_identifier
HF_TOKEN=your_hf_api_key
# Required only if your inference implementation uses from_docker_image():
LOCAL_IMAGE_NAME=

# Optional provider hint used for diagnostics only.
LLM_PROVIDER=openai

# Optional compatibility alias for API base override
LLM_API_BASE_URL=

# Optional backward compatibility var (not required by submission rules)
OPENAI_API_KEY=

# Optional: environment server URL for inference.py
ENV_BASE_URL=http://localhost:8000
# Optional additional fallback endpoints (comma-separated)
ENV_BASE_URL_FALLBACKS=
# Optional Hugging Face Space URL used as automatic fallback if local env is unavailable
HF_SPACE_URL=https://thomastv-openenv-customer-ticket-triage.hf.space

# Baseline control
# RUN_ALL_TASKS=1 runs TASKS and emits a [BASELINE] summary line.
RUN_ALL_TASKS=1
TASKS=easy,medium,hard
TASK_NAME=easy

# Optional inference runtime tuning
MAX_STEPS=70
TEMPERATURE=0.0
SEED=42

# LLM call controls for free-tier quotas
MAX_LLM_CALLS_PER_TASK=8
LLM_RETRY_MAX=2
LLM_RETRY_SECONDS=35

# Ollama local alternative
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
# LLM_API_BASE_URL=http://localhost:11434/v1

# Optional server log level (structured JSON logging)
LOG_LEVEL=INFO
LOG_TO_FILE=0
LOG_FILE_PATH=logs/server.jsonl

# Inference logging mode
# 0 = normal mode (errors + final scores only)
# 1 = verbose mode (logs all request/step details)
INFERENCE_VERBOSE=0
INFERENCE_LOG_TO_FILE=0
INFERENCE_LOG_FILE_PATH=logs/inference.log
